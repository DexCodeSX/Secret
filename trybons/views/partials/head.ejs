<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title === 'string' ? title + ' · trybons' : 'trybons — open source dashboard' %></title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%2334d399'><path d='M12 2L4 12l8 10 8-10L12 2z'/></svg>" />
  <script src="https://cdn.tailwindcss.com?plugins=typography,forms"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'], mono: ['JetBrains Mono', 'monospace'] },
          colors: {
            ink: { 950: '#0a0a0a', 900: '#0f0f0f', 850: '#141414', 800: '#1a1a1a', 750: '#222', 700: '#2a2a2a' },
            accent: { 400: '#34d399', 500: '#10b981', 600: '#059669' },
          },
          animation: {
            'fade-in': 'fade 0.3s ease-out',
            'slide-up': 'slide 0.4s ease-out',
            'shimmer': 'shimmer 2s linear infinite',
          },
          keyframes: {
            fade: { '0%': { opacity: 0 }, '100%': { opacity: 1 } },
            slide: { '0%': { transform: 'translateY(8px)', opacity: 0 }, '100%': { transform: 'translateY(0)', opacity: 1 } },
            shimmer: { '0%': { backgroundPosition: '-200% 0' }, '100%': { backgroundPosition: '200% 0' } },
          },
        },
      },
    };
  </script>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    body { background: #0a0a0a; color: #e5e5e5; font-family: 'Inter', system-ui, sans-serif; }
    .glass { background: rgba(20,20,20,0.7); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.06); }
    .grad-text { background: linear-gradient(135deg, #34d399, #10b981, #6ee7b7); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .grad-text-multi { background: linear-gradient(135deg, #34d399, #3b82f6, #8b5cf6, #34d399); background-size: 200% 200%; -webkit-background-clip: text; background-clip: text; color: transparent; animation: shimmer 6s ease infinite; }
    .grad-border { position: relative; }
    .grad-border::before { content:''; position:absolute; inset:0; padding:1px; background:linear-gradient(135deg,#34d399,#10b981,#3b82f6); -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor; mask-composite: exclude; border-radius:inherit; pointer-events:none; }
    [hx-indicator].htmx-request { opacity: 1; }
    [hx-indicator] { opacity: 0; transition: opacity .2s; }
    .pulse-dot { animation: pulse 2s infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: .4; } }
    .glow { box-shadow: 0 0 80px rgba(52, 211, 153, 0.15); }
    .glow-blue { box-shadow: 0 0 80px rgba(59, 130, 246, 0.15); }
    .scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
    .scrollbar::-webkit-scrollbar-thumb { background: #2a2a2a; border-radius: 3px; }
    .scrollbar::-webkit-scrollbar-thumb:hover { background: #3a3a3a; }
    .scrollbar::-webkit-scrollbar-track { background: transparent; }
    .grid-bg {
      background-image:
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
      background-size: 32px 32px;
    }
  </style>
</head>
<body class="min-h-screen antialiased scrollbar">
  <% if (typeof flash === 'object' && flash) { %>
    <div class="fixed top-4 right-4 z-50 animate-slide-up">
      <div class="glass rounded-lg px-4 py-3 text-sm <%= flash.type === 'error' ? 'border-red-500/40 text-red-300' : 'border-emerald-500/40 text-emerald-300' %>">
        <%= flash.msg %>
      </div>
    </div>
  <% } %>
