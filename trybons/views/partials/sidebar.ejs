<aside class="w-60 border-r border-ink-700/50 bg-ink-900 flex flex-col">
  <div class="p-5 border-b border-ink-700/50">
    <a href="/" class="flex items-center gap-2.5 group">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center shadow-lg shadow-emerald-500/20">
        <svg class="w-4 h-4 text-ink-950" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L4 12l8 10 8-10L12 2z"/></svg>
      </div>
      <div>
        <div class="font-bold text-sm leading-tight">trybons</div>
        <div class="text-xs text-zinc-500 font-mono leading-tight">ui · open source</div>
      </div>
    </a>
  </div>
  <nav class="flex-1 p-3 space-y-0.5">
    <% const items = [
      ['/dashboard', 'overview', 'M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z'],
      ['/dashboard/keys', 'api keys', 'M21 10h-8.35A5.99 5.99 0 0 0 7 6c-3.31 0-6 2.69-6 6s2.69 6 6 6a5.99 5.99 0 0 0 5.65-4H13l2 2 2-2 2 2 4-4.05L21 10zM7 15c-1.65 0-3-1.35-3-3s1.35-3 3-3 3 1.35 3 3-1.35 3-3 3z'],
      ['/dashboard/activity', 'activity', 'M19.36 9.43L19 8l-1.43-.36-1.43-1.43L16 5l-1.43.36L13.43 4 13 2.36 11.57 4 10 3.64 9.64 5 8.21 5.36 7 7l1.43.36L9 9l1.43-.36L11.43 9.43 12 10.86l.43-1.43L13.43 8.43 14.86 8l-.43-1.43L13 5.07 14 4 12.86 3 12 4l-.86-1L10 4l-1 1L7.86 5l1 1.14L8 7l1.14.86L9 9l1.14.86L11 9l1.14.86L12 11l1 .86L14 11l.86 1.14L16 11l.86 1.14L18 11l.86 1.14z'],
      ['/dashboard/models', 'models', 'M12 2c-5.5 0-10 4.5-10 10s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.4 0-8-3.6-8-8s3.6-8 8-8 8 3.6 8 8-3.6 8-8 8zm-3-9h6v2H9v-2z'],
      ['/dashboard/settings', 'settings', 'M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.488.488 0 0 0-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54a.484.484 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94 0 .32.02.64.07.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z'],
      ['/docs', 'docs', 'M4 19.5A2.5 2.5 0 0 1 6.5 17H20M4 19.5A2.5 2.5 0 0 0 6.5 22H20v-2H6.5a.5.5 0 0 1 0-1H20V4H6.5A2.5 2.5 0 0 0 4 6.5v13z'],
    ]; %>
    <% items.forEach(([href, label, icon]) => { %>
      <a href="<%= href %>" class="flex items-center gap-2.5 px-3 py-2 text-sm rounded-md transition-all <%= path === href ? 'bg-emerald-500/10 text-emerald-400 font-medium' : 'text-zinc-400 hover:text-white hover:bg-ink-800' %>">
        <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="<%= icon %>"/></svg>
        <%= label %>
      </a>
    <% }); %>
  </nav>
  <div class="p-3 border-t border-ink-700/50 relative" id="user-menu-wrap">
    <% if (user) { %>
      <button onclick="toggleProfileMenu()" id="user-trigger"
        class="w-full flex items-center gap-2.5 px-2 py-2 hover:bg-ink-800/60 rounded-md transition-colors text-left group">
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-500 to-emerald-700 flex items-center justify-center text-sm font-bold text-ink-950 flex-shrink-0">
          <%= (user.first_name || user.email || '?').charAt(0).toUpperCase() %>
        </div>
        <div class="min-w-0 flex-1">
          <div class="text-xs font-medium truncate"><%= user.first_name || 'user' %> <%= user.last_name || '' %></div>
          <div class="text-xs text-zinc-500 truncate"><%= user.email %></div>
        </div>
        <svg class="w-3.5 h-3.5 text-zinc-500 group-hover:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"/></svg>
      </button>
      <div id="profile-menu" class="absolute bottom-16 left-3 right-3 hidden z-50"
        hx-get="/profiles" hx-trigger="revealed" hx-swap="innerHTML">
        <div class="text-xs text-zinc-500 px-3 py-2">loading...</div>
      </div>
      <script>
        function toggleProfileMenu() {
          const m = document.getElementById('profile-menu');
          m.classList.toggle('hidden');
          if (!m.classList.contains('hidden') && window.htmx) htmx.trigger(m, 'revealed');
        }
        document.addEventListener('click', e => {
          if (!document.getElementById('user-menu-wrap')?.contains(e.target)) {
            document.getElementById('profile-menu')?.classList.add('hidden');
          }
        });
      </script>
    <% } %>
  </div>
</aside>
