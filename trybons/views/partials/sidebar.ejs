<aside class="w-60 border-r border-ink-700/50 bg-ink-900 flex flex-col">
  <div class="p-5 border-b border-ink-700/50">
    <a href="/" class="flex items-center gap-2.5 group">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center shadow-lg shadow-emerald-500/20">
        <svg class="w-4 h-4 text-ink-950" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L4 12l8 10 8-10L12 2z"/></svg>
      </div>
      <div>
        <div class="font-bold text-sm leading-tight">trybons</div>
        <div class="text-xs text-zinc-500 font-mono leading-tight">ui · open source</div>
      </div>
    </a>
  </div>
  <nav class="flex-1 p-3 space-y-0.5">
    <%
      // Lucide-style stroke icons. each entry: [href, label, svgInnerMarkup].
      // svg wrapper applies stroke=currentColor + stroke-width=2 so all stays consistent.
      const items = [
        // overview = layout-dashboard (4 panels)
        ['/dashboard', 'overview',
          '<rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/>'],
        // api keys = key
        ['/dashboard/keys', 'api keys',
          '<circle cx="7.5" cy="15.5" r="3.5"/><path d="M10 13l8.5-8.5"/><path d="M16 6l3 3"/><path d="M14 8l3 3"/>'],
        // activity = pulse line (a clear ECG/heartbeat) — way better than the old sparkle
        ['/dashboard/activity', 'activity',
          '<path d="M3 12h4l2-7 4 14 2-7h6"/>'],
        // models = sparkles (modern AI convention, used by every AI app in 2026)
        ['/dashboard/models', 'models',
          '<path d="M12 3l1.5 4.5L18 9l-4.5 1.5L12 15l-1.5-4.5L6 9l4.5-1.5z"/><path d="M19 14l.7 2.1L22 17l-2.3.9L19 20l-.7-2.1L16 17l2.3-.9z"/><path d="M5 17l.5 1.5L7 19l-1.5.5L5 21l-.5-1.5L3 19l1.5-.5z"/>'],
        // settings = cog
        ['/dashboard/settings', 'settings',
          '<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>'],
        // docs = book-open (much clearer than the old book-corner shape)
        ['/docs', 'docs',
          '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>'],
      ];
    %>
    <% items.forEach(([href, label, icon]) => { %>
      <a href="<%= href %>" class="flex items-center gap-2.5 px-3 py-2 text-sm rounded-md transition-all <%= path === href ? 'bg-emerald-500/10 text-emerald-400 font-medium' : 'text-zinc-400 hover:text-white hover:bg-ink-800' %>">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><%- icon %></svg>
        <%= label %>
      </a>
    <% }); %>
  </nav>
  <div class="p-3 border-t border-ink-700/50 relative" id="user-menu-wrap">
    <% if (user) { %>
      <button onclick="toggleProfileMenu()" id="user-trigger"
        class="w-full flex items-center gap-2.5 px-2 py-2 hover:bg-ink-800/60 rounded-md transition-colors text-left group">
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-500 to-emerald-700 flex items-center justify-center text-sm font-bold text-ink-950 flex-shrink-0">
          <%= (user.first_name || user.email || '?').charAt(0).toUpperCase() %>
        </div>
        <div class="min-w-0 flex-1">
          <div class="text-xs font-medium truncate"><%= user.first_name || 'user' %> <%= user.last_name || '' %></div>
          <div class="text-xs text-zinc-500 truncate"><%= user.email %></div>
        </div>
        <svg class="w-3.5 h-3.5 text-zinc-500 group-hover:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"/></svg>
      </button>
      <div id="profile-menu" class="absolute bottom-16 left-3 right-3 hidden z-50"
        hx-get="/profiles" hx-trigger="revealed" hx-swap="innerHTML">
        <div class="text-xs text-zinc-500 px-3 py-2">loading...</div>
      </div>
      <script>
        function toggleProfileMenu() {
          const m = document.getElementById('profile-menu');
          m.classList.toggle('hidden');
          if (!m.classList.contains('hidden') && window.htmx) htmx.trigger(m, 'revealed');
        }
        document.addEventListener('click', e => {
          if (!document.getElementById('user-menu-wrap')?.contains(e.target)) {
            document.getElementById('profile-menu')?.classList.add('hidden');
          }
        });
      </script>
    <% } %>
  </div>
</aside>
