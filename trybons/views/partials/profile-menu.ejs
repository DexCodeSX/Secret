<div class="glass rounded-xl p-2 w-72 max-h-[80vh] overflow-y-auto scrollbar shadow-2xl border border-ink-700">
  <div class="px-3 py-2 border-b border-ink-700/50 mb-1">
    <div class="text-xs text-zinc-500 uppercase tracking-wider mb-2">signed in as</div>
    <div class="flex items-center gap-2.5">
      <div class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-500 to-emerald-700 flex items-center justify-center text-sm font-bold text-ink-950 flex-shrink-0">
        <%= (user?.first_name || user?.email || '?').charAt(0).toUpperCase() %>
      </div>
      <div class="min-w-0 flex-1">
        <div class="text-sm font-medium truncate"><%= user?.first_name || 'user' %> <%= user?.last_name || '' %></div>
        <div class="text-xs text-zinc-500 truncate"><%= user?.email %></div>
      </div>
      <span class="text-xs text-emerald-400 font-mono pulse-dot">●</span>
    </div>
  </div>

  <% const others = profiles.filter(p => p.email !== user?.email); %>
  <% if (others.length > 0) { %>
    <div class="px-3 py-1 text-xs text-zinc-500 uppercase tracking-wider mt-1 mb-1">switch to (<%= others.length %>)</div>
    <% others.forEach(p => { %>
      <form method="post" action="/profiles/<%= encodeURIComponent(p.name) %>/switch" class="block">
        <button class="w-full px-2 py-2 hover:bg-ink-800/60 rounded-md transition-colors text-left flex items-center gap-2.5 group min-h-[44px]">
          <div class="w-7 h-7 rounded-full bg-zinc-700/60 flex items-center justify-center text-xs font-bold text-zinc-300 flex-shrink-0 group-hover:bg-emerald-500/20 group-hover:text-emerald-400">
            <%= p.email.charAt(0).toUpperCase() %>
          </div>
          <div class="min-w-0 flex-1">
            <div class="text-sm text-zinc-300 truncate"><%= p.name %></div>
            <div class="text-xs text-zinc-500 truncate"><%= p.email %></div>
          </div>
          <svg class="w-3.5 h-3.5 text-zinc-600 group-hover:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </button>
      </form>
    <% }); %>
  <% } else if (profiles.length > 0) { %>
    <div class="mx-3 my-2 px-3 py-2 bg-amber-500/10 border border-amber-500/20 rounded-lg text-xs text-amber-300/90 leading-relaxed">
      <strong>only one account saved.</strong> all <%= profiles.length %> profile<%= profiles.length === 1 ? '' : 's' %> use the same email
      so switching won't change anything.
    </div>
  <% } %>

  <div class="border-t border-ink-700/50 mt-1 pt-1">
    <!-- the smart "add another" — saves current, logs out, opens /login in one click -->
    <form method="post" action="/profiles/add-account">
      <button class="w-full flex items-center gap-2.5 px-3 py-2.5 text-sm text-emerald-400 hover:bg-emerald-500/10 rounded-md transition-colors text-left min-h-[44px]">
        <div class="w-7 h-7 rounded-full bg-emerald-500/15 border border-emerald-500/30 flex items-center justify-center flex-shrink-0">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m6-6H6"/></svg>
        </div>
        <div class="min-w-0 flex-1">
          <div class="text-sm font-medium">add another account</div>
          <div class="text-xs text-zinc-500 leading-tight">saves current → sign in w/ different email</div>
        </div>
      </button>
    </form>

    <a href="/dashboard/settings#profiles" class="flex items-center gap-2.5 px-3 py-2 text-sm text-zinc-400 hover:text-white hover:bg-ink-800/60 rounded-md transition-colors min-h-[44px]">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      manage profiles
    </a>

    <form method="post" action="/logout">
      <button class="w-full flex items-center gap-2.5 px-3 py-2 text-sm text-zinc-400 hover:text-red-400 hover:bg-red-500/10 rounded-md transition-colors text-left min-h-[44px]">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      sign out
      </button>
    </form>
  </div>
</div>
