<div class="glass rounded-xl p-2 w-72 max-h-96 overflow-y-auto scrollbar shadow-2xl border border-ink-700">
  <div class="px-3 py-2 border-b border-ink-700/50 mb-1">
    <div class="text-xs text-zinc-500 uppercase tracking-wider mb-2">current</div>
    <div class="flex items-center gap-2.5">
      <div class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-500 to-emerald-700 flex items-center justify-center text-sm font-bold text-ink-950 flex-shrink-0">
        <%= (user?.first_name || user?.email || '?').charAt(0).toUpperCase() %>
      </div>
      <div class="min-w-0 flex-1">
        <div class="text-sm font-medium truncate"><%= user?.first_name || 'user' %></div>
        <div class="text-xs text-zinc-500 truncate"><%= user?.email %></div>
      </div>
      <span class="text-xs text-emerald-400 font-mono">●</span>
    </div>
  </div>

  <% if (profiles.length > 0) { %>
    <div class="px-3 py-1 text-xs text-zinc-500 uppercase tracking-wider mt-1 mb-1">switch to</div>
    <% profiles.forEach(p => { %>
      <% if (p.email === user?.email) return; %>
      <form method="post" action="/profiles/<%= encodeURIComponent(p.name) %>/switch" class="block">
        <button class="w-full px-2 py-2 hover:bg-ink-800/60 rounded-md transition-colors text-left flex items-center gap-2.5 group">
          <div class="w-7 h-7 rounded-full bg-zinc-700/60 flex items-center justify-center text-xs font-bold text-zinc-300 flex-shrink-0 group-hover:bg-emerald-500/20 group-hover:text-emerald-400">
            <%= p.email.charAt(0).toUpperCase() %>
          </div>
          <div class="min-w-0 flex-1">
            <div class="text-sm text-zinc-300 truncate"><%= p.name %></div>
            <div class="text-xs text-zinc-500 truncate"><%= p.email %></div>
          </div>
          <svg class="w-3.5 h-3.5 text-zinc-600 group-hover:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </button>
      </form>
    <% }); %>
  <% } %>

  <div class="border-t border-ink-700/50 mt-1 pt-1">
    <a href="/dashboard/settings#profiles" class="flex items-center gap-2 px-3 py-2 text-sm text-zinc-400 hover:text-emerald-400 hover:bg-ink-800/60 rounded-md transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      add another account
    </a>
    <form method="post" action="/logout">
      <button class="w-full flex items-center gap-2 px-3 py-2 text-sm text-zinc-400 hover:text-red-400 hover:bg-red-500/10 rounded-md transition-colors text-left">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        sign out
      </button>
    </form>
  </div>
</div>
